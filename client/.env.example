# ============================================
# VisionCure Frontend — Environment Variables
# ============================================
# In DEVELOPMENT: Leave VITE_API_URL empty — Vite proxy handles /api/* → localhost:3001
# In PRODUCTION:  Set this to your deployed backend URL (no trailing slash)
#
# Example: VITE_API_URL=https://visioncure-api.railway.app
#
# Set this in:
#   - Vercel dashboard → Project Settings → Environment Variables
#   - OR create a .env.local file here (never commit it)

VITE_API_URL=
