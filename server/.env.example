# ============================================
# VisionCure Backend — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit the actual .env file to Git
# ============================================

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/visioncure?retryWrites=true&w=majority

# Auth
JWT_SECRET=a_long_random_secret_string_at_least_32_chars

# Integrations (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Calendar (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend.railway.app/api/auth/google/callback

# Server
PORT=3001
